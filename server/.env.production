# AZMusic Server - Production Environment Configuration
# =====================================================
# Copy this file to .env when deploying the production server.
# All sensitive values (like LAN_AUTH_TOKEN) should be generated fresh.
#
# Generate a strong auth token with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# Application
APP_NAME=AZMusic
HOST=0.0.0.0
PORT=8795
DEBUG=false

# PRODUCTION MODE — Required for distribution
# These three settings MUST be set to these values for production.
PRODUCTION_MODE=true
REQUIRE_DEVICE_AUTH=true
ALLOW_STUB_MUSICXML=false

# Database
# Relative SQLite paths are resolved from server/
DATABASE_URL=sqlite+aiosqlite:///./azmusic_server.db

# File storage
# Relative paths are resolved from server/
STORAGE_PATH=./storage

# LAN authentication / QR-paired devices
# REQUIRE_DEVICE_AUTH=true enforces QR-paired tokens on all API endpoints.
# LAN_AUTH_TOKEN is a legacy v1 placeholder — leave empty.
LAN_AUTH_TOKEN=
# Optional: override the server URL embedded in QR codes if auto-detection
# picks the wrong network interface. Example: PUBLIC_SERVER_URL=http://192.168.1.100:8795
PUBLIC_SERVER_URL=

# AI and processing
AI_ENABLED=true
MAX_CONCURRENT_JOBS=2
OCR_CLI_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe
OCR_LANGUAGE=eng
PROCESSING_MODE=server_only
JOB_DISPATCHER_ENABLED=true
JOB_DISPATCHER_POLL_INTERVAL_SECONDS=2.0
JOB_DISPATCHER_STALE_AFTER_SECONDS=600
JOB_DISPATCHER_MAX_RETRIES=2

# Optional AI/cloud paths (leave blank if not used)
LEGATO_CLI_PATH=
LEGATO_MODEL_PATH=
AUDIVERIS_CLI_PATH=
HOMR_CLI_PATH=
MUSESCORE_CLI_PATH=
GEMINI_OAUTH_CLIENT_SECRET_PATH=
GEMINI_OAUTH_REDIRECT_BASE_URL=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

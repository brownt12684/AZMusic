# AZMusic Server - Environment Configuration
# Copy this file to .env and adjust values as needed.

# Application
APP_NAME=AZMusic
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database
# Relative SQLite paths are resolved from server/.
DATABASE_URL=sqlite+aiosqlite:///./azmusic_server.db

# File storage
# Relative paths are resolved from server/.
STORAGE_PATH=./storage

# LAN authentication (v1 placeholder)
# Generate a strong token: python -c "import secrets; print(secrets.token_urlsafe(32))"
LAN_AUTH_TOKEN=

# AI and processing
AI_ENABLED=true
MAX_CONCURRENT_JOBS=2

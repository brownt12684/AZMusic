# AZMusic Server - Environment Configuration
# Copy this file to .env and adjust values as needed.

# Application
APP_NAME=AZMusic
HOST=0.0.0.0
PORT=8795
DEBUG=false
PRODUCTION_MODE=false

# Database
# Relative SQLite paths are resolved from server/.
DATABASE_URL=sqlite+aiosqlite:///./azmusic_server.db

# File storage
# Relative paths are resolved from server/.
STORAGE_PATH=./storage

# LAN authentication / QR-paired devices
# Set REQUIRE_DEVICE_AUTH=true for production student packages.
LAN_AUTH_TOKEN=
REQUIRE_DEVICE_AUTH=false
# Optional override for QR pairing payloads when auto-detection chooses the wrong LAN address.
PUBLIC_SERVER_URL=

# AI and processing
AI_ENABLED=true
MAX_CONCURRENT_JOBS=2
AUDIVERIS_CLI_PATH=
HOMR_CLI_PATH=
LEGATO_CLI_PATH=
LEGATO_MODEL_PATH=
MUSESCORE_CLI_PATH=
OCR_CLI_PATH=
OCR_LANGUAGE=eng
PROCESSING_MODE=server_only
# Production packages must run with ALLOW_STUB_MUSICXML=false.
ALLOW_STUB_MUSICXML=true
JOB_DISPATCHER_ENABLED=true
JOB_DISPATCHER_POLL_INTERVAL_SECONDS=2.0
JOB_DISPATCHER_STALE_AFTER_SECONDS=600
JOB_DISPATCHER_MAX_RETRIES=2
GEMINI_OAUTH_CLIENT_SECRET_PATH=
GEMINI_OAUTH_REDIRECT_BASE_URL=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# YouTube Data API v3
# Required for Accompaniments & Reference Media search.
# Get a key: https://console.cloud.google.com/ → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=
